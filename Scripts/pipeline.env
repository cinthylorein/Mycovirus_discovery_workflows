#!/usr/bin/env bash
# Central config for Virus_discovery_workflows (portable across Slurm clusters)
# Edit PIPELINE_ROOT (and optionally PROJECT) to match your environment.

# 1) REQUIRED: where the project folder lives (user chooses)
export PIPELINE_ROOT="${PIPELINE_ROOT:-/workspace/$USER/Virus_discovery_workflows/MVoPvirome}"

# 2) REQUIRED: the project folder name inside PIPELINE_ROOT
export PROJECT="${PROJECT:-MVoP_pipeline}"

# 3) Optional: scratch/temp location (falls back safely)
export SCRATCH_ROOT="${SCRATCH_ROOT:-${SLURM_TMPDIR:-${PIPELINE_ROOT}/${PROJECT}/tmp}}"

# ---- Derived paths (do not edit) ----
export PROJECT_DIR="${PIPELINE_ROOT}/${PROJECT}"

export SCRIPTS_DIR="${PROJECT_DIR}/scripts"
export CONFIG_DIR="${PROJECT_DIR}/config"

export LOG_DIR="${PROJECT_DIR}/logs"
export ACCESSION_DIR="${PROJECT_DIR}/accession_lists"
export ADAPTER_DIR="${PROJECT_DIR}/adapters"
#export ENV_DIR="${PROJECT_DIR}/environments"

export RAW_DIR="${PROJECT_DIR}/raw_reads"
export FASTQC_DIR="${PROJECT_DIR}/fastqc"
export TRIM_DIR="${PROJECT_DIR}/trimmed_reads"
export CONTIGS_DIR="${PROJECT_DIR}/contigs"
export MAPPING_DIR="${PROJECT_DIR}/mapping"
export ANNOTATION_DIR="${PROJECT_DIR}/annotation"
export BLAST_DIR="${PROJECT_DIR}/blast_results"

# Convenience: ensure essential dirs exist when sourced
mkdir -p "$LOG_DIR" "$ACCESSION_DIR"